/* PÁGINA ENTERA EN CREMITA OSCURO */
html, body {
    background: #e8dcc7;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
}

body {
    display: block;
}

/* CONTENEDOR */
.container {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: 70px 1fr 70px;
    background: transparent;
}

/* BARRA LATERAL IZQUIERDA */
.sidebar {
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 25px;
}

/* BOTONES LATERALES BASE */
.side-icon {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.25);
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* ❤️ PRIMER BOTÓN DE LA BARRA IZQUIERDA: CORAZÓN */
.heart-btn {
    background: none !important;
    border: none;
    padding: 0;
    width: 75px;
    height: 75px;
    display: flex;
    justify-content: center;
    align-items: center;
}

.heart-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
}

/* CONTENIDO CENTRAL */
.main {
    padding: 40px 40px;
    display: flex;
    flex-direction: column;
    position: relative;
}

/* BOTÓN IZQUIERDA — ICONO APLICADO AQUÍ */
.main-left-btn {
    position: absolute;
    left: -50px;
    top: -30px;
    width: 200px;
    height: 200px;
    border-radius: 10px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
}

.main-left-btn img { 
    width: 100%; 
    height: 100%; 
    display: block;
    background: none;
    border: none;
    padding: 0;
}

/* BARRA DE BÚSQUEDA */
.search-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
}

.search-wrapper input {
    width: 80%;
    padding: 20px 25px;
    font-size: 20px;
    border-radius: 50px;
    border: none;
    outline: none;

    background: rgba(163, 104, 79, 0.55);
    backdrop-filter: blur(6px);
    color: #fff;
}


/* BOTONES INFERIORES DERECHA */
.bottom-right-buttons {
    position: absolute;
    bottom: -10px;
    right: 30px;
    display: flex;
    gap: 12px;
}

.br-btn {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
}

