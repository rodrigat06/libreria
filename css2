/* Imagen centrada hacia la izquierda */
.left-center-image {
    position: absolute;
    left: 350px;        /* distancia desde la izquierda */
    top: 50%;           /* centro vertical */
    transform: translateY(-50%);
    display: flex;
    justify-content: center;
    align-items: center;
}

.left-center-image img {
    width: 260px;       /* tamaño de la imagen */
    height: auto;
    border-radius: 10px;
}

.book-image-container {
  position: relative;
  width: 260px; /* o el tamaño que estés usando */
}

.book-image {
  width: 100%;
  height: auto;
  border-radius: 10px;
}

/* Estrella en la esquina superior derecha */
.book-image-container {
  position: relative;
  width: 260px; /* o el tamaño que estés usando */
}

.book-image {
  width: 100%;
  height: auto;
  border-radius: 10px;
}

/* Botón de estrella en la esquina superior derecha */
.star-btn-overlay {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 50px;
  height: 50px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  display: flex;
  justify-content: center;
  align-items: center;
}

.star-btn-overlay img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* Panel de información a la derecha del libro */
.book-info-panel {
    position: absolute;
    left: 650px;   /* Ajusta según dónde tengas la portada */
    top: 50%;
    transform: translateY(-50%);
    width: 350px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: Arial, sans-serif;
}

.info-title {
    margin: 0 0 10px;
    font-size: 26px;
    font-weight: bold;
}

.info-label {
    margin: 5px 0 3px;
    font-weight: bold;
    font-size: 16px;
}

.info-box {
    width: 100%;
    height: 35px;
    border-radius: 6px;
}

/* Botón negro */
.read-button {
    margin-top: 15px;
    width: 200px;
    height: 45px;
    background: black;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    cursor: pointer;
}



